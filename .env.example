# Copy to .env for local development. Do not commit .env.
# For EAS Build, set the same keys as EAS project environment variables
# (expo.dev → Project → Environment variables).

EXPO_PUBLIC_APP_ENV=development

# Firebase Web SDK (worknet-orbitra)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=worknet-orbitra.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=worknet-orbitra
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=worknet-orbitra.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Google Sign-In (OAuth Web client ID from Firebase / Google Cloud)
EXPO_PUBLIC_WEB_CLIENT_ID=

# Google Maps (restrict by bundle id + SHA-1 in Google Cloud Console)
GOOGLE_MAPS_API_KEY=

# EAS file secrets (upload with: bun run eas:sync-secrets)
# GOOGLE_SERVICES_JSON=./google-services.json
# GOOGLE_SERVICE_INFO_PLIST=./GoogleService-Info.plist

# EAS Submit (store submission only — set in EAS dashboard, not required locally)
# ASC_APP_ID=
