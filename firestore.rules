rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function validReview() {
      return request.resource.data.userId == request.auth.uid
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.providerId is string
        && request.resource.data.userName is string;
    }

    function nicUnchanged() {
      return !('nicNumber' in resource.data)
        || resource.data.nicNumber == request.resource.data.nicNumber
        || resource.data.nicNumber == null
        || resource.data.nicNumber == '';
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /sessions/{sessionId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /service_providers/{providerId} {
      allow read: if true;
      allow create: if isOwner(providerId);
      allow update: if isOwner(providerId) && nicUnchanged();
      allow delete: if isOwner(providerId);
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && validReview();
      allow update, delete: if false;
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if false;
    }

    match /saved_providers/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
