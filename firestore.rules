rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function validReview() {
      return request.resource.data.userId == request.auth.uid
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.providerId is string
        && request.resource.data.userName is string;
    }

    function validReport() {
      return request.resource.data.reporterId == request.auth.uid
        && request.resource.data.targetType in ['review', 'provider']
        && request.resource.data.targetId is string
        && request.resource.data.reason is string
        && request.resource.data.reason.size() >= 3
        && request.resource.data.reason.size() <= 500;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /sessions/{sessionId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /provider_verification/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /service_providers/{providerId} {
      allow read: if true;
      allow create: if isOwner(providerId)
        && !('nicNumber' in request.resource.data);
      allow update: if isOwner(providerId)
        && !('nicNumber' in request.resource.data)
        && (
          !('nicNumber' in resource.data)
          || resource.data.nicNumber == null
          || resource.data.nicNumber == ''
        );
      allow delete: if isOwner(providerId);
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && validReview();
      allow update, delete: if false;
    }

    match /reports/{reportId} {
      allow create: if isAuthenticated() && validReport();
      allow read, update, delete: if false;
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if false;
    }

    match /saved_providers/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
