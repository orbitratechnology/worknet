rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function validReview() {
      return request.resource.data.userId == request.auth.uid
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.providerId is string
        && request.resource.data.userName is string;
    }

    function validReport() {
      return request.resource.data.reporterId == request.auth.uid
        && request.resource.data.targetType in ['review', 'provider']
        && request.resource.data.targetId is string
        && request.resource.data.reason is string
        && request.resource.data.reason.size() >= 3
        && request.resource.data.reason.size() <= 500;
    }

    function validNicNumber(nic) {
      return nic is string
        && (nic.matches('^[0-9]{9}[vV]$') || nic.matches('^[0-9]{12}$'));
    }

    function verifiedIdentityImmutable() {
      return (
        !(resource.data.get('nicVerified', false) == true)
        || (
          request.resource.data.get('nicVerified', false) == true
          && request.resource.data.nicNumber == resource.data.nicNumber
        )
      ) && (
        !(resource.data.get('phoneVerified', false) == true)
        || (
          request.resource.data.get('phoneVerified', false) == true
          && request.resource.data.phoneNumber == resource.data.phoneNumber
        )
      );
    }

    match /users/{userId} {
      allow read, create, delete: if isOwner(userId);
      allow update: if isOwner(userId) && verifiedIdentityImmutable();

      match /sessions/{sessionId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /nic_registry/{nic} {
      allow read, write: if false;
    }

    match /provider_verification/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId)
        && (
          !('nicNumber' in request.resource.data)
          || validNicNumber(request.resource.data.nicNumber)
        );
      allow update: if isOwner(userId)
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['nicNumber'])
          || request.resource.data.nicNumber == resource.data.nicNumber
          || (
            !('nicNumber' in resource.data)
            && validNicNumber(request.resource.data.nicNumber)
          )
        )
        && (
          !('nicNumber' in request.resource.data)
          || validNicNumber(request.resource.data.nicNumber)
        );
      allow delete: if false;
    }

    match /service_providers/{providerId} {
      allow read: if true;
      allow create: if isOwner(providerId)
        && !('nicNumber' in request.resource.data);
      allow update: if isOwner(providerId)
        && !('nicNumber' in request.resource.data)
        && (
          !('nicNumber' in resource.data)
          || resource.data.nicNumber == null
          || resource.data.nicNumber == ''
        );
      allow delete: if isOwner(providerId);
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && validReview();
      allow update, delete: if false;
    }

    match /reports/{reportId} {
      allow create: if isAuthenticated() && validReport();
      allow read, update, delete: if false;
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if false;
    }

    match /saved_providers/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
