rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Basic owner check
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Profile photos: Anyone can read, only owner can upload
    match /profile_photos/{userId}/{fileName} {
      allow read: if true;
      allow write: if isOwner(userId);
    }
    
    // Work Samples / Portfolio: Public viewing, restricted upload
    match /work_samples/{userId}/{fileName} {
      allow read: if true;
      allow write: if isOwner(userId);
    }

    match /portfolio_images/{userId}/{fileName} {
      allow read: if true;
      allow write: if isOwner(userId);
    }

    // Private user files if any (e.g. settings documents)
    match /private/{userId}/{allPaths=**} {
      allow read, write: if isOwner(userId);
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
